{
  "version": 2,
  "routes": [
    {
      "src": "/api/callback",
      "dest": "api/callback.js"
    },
    {
      "src": "/api/signup",
      "dest": "api/signup.js"
    },
    {
      "src": "/api/redeem",
      "dest": "api/redeem.js"
    },
    {
      "src": "/api/ai",
      "dest": "api/ai.js"
    },
    {
      "src": "/api/daily",
      "dest": "api/daily.js"
    },
    {
      "src": "/api/referral/(.*)",
      "dest": "api/referral.js"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
