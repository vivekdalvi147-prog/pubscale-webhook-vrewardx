{
  "version": 2,
  "routes": [
    {
      "src": "/api/callback",
      "dest": "api/callback.js"
    },
    {
      "src": "/api/signup",
      "dest": "api/signup.js"
    },
    {
      "src": "/api/redeem",
      "dest": "api/redeem.js"
    },
    {
      "src": "/api/bol-ai",
      "dest": "api/bol-ai.js"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
